{
  "redirects": [
    { "source": "/", "destination": "/index.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/auth/:path*",     "destination": "/api/index.py" },
    { "source": "/teams/:path*",    "destination": "/api/index.py" },
    { "source": "/tasks/:path*",    "destination": "/api/index.py" },
    { "source": "/messages/:path*", "destination": "/api/index.py" }
  ]
}
